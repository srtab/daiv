DAIV_SANDBOX_API_KEY=notsosecret
DAIV_SANDBOX_RUNTIME=runsc
DAIV_SANDBOX_LOG_LEVEL=DEBUG
DAIV_SANDBOX_ENVIRONMENT=local
DAIV_SANDBOX_REDIS_URL=redis://redis:6379/1
# Attach network-enabled cmd-executor containers to the compose network so they can
# reach sibling services (e.g. gitlab:8929).
DAIV_SANDBOX_NETWORK=daiv_default
# Under gVisor (runsc) the cmd-executor can't use Docker's embedded resolver (127.0.0.11) that the
# user-defined network injects, so resolv.conf is repointed at real upstreams (DAIV_SANDBOX_DNS,
# default 1.1.1.1,8.8.8.8) for external names, and these sibling services are pinned in /etc/hosts.
DAIV_SANDBOX_EXTRA_HOSTS=gitlab

