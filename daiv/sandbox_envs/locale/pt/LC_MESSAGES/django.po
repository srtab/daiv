msgstr "Nome inválido"

msgid "Duplicate name"
msgstr "Nome duplicado"

msgid "Environment variables"
msgstr "Variáveis de ambiente"

msgid "Paste .env"
msgstr "Colar .env"

msgid "🔒 keep existing"
msgstr "🔒 manter existente"

msgid "value"
msgstr "valor"

