#, python-format
msgid "%(repos)s and %(remaining)d more"
msgstr "%(repos)s e mais %(remaining)d"

#, python-format
msgid "'%(name)s' succeeded on %(repo)s — %(owner)s"
msgstr "'%(name)s' teve sucesso em %(repo)s — %(owner)s"

#, python-format
msgid "Scheduled run '%(name)s' by %(owner)s finished on %(repo)s."
msgstr "A execução agendada '%(name)s' de %(owner)s terminou em %(repo)s."

#, python-format
msgid "'%(name)s' failed on %(repo)s — %(owner)s"
msgstr "'%(name)s' falhou em %(repo)s — %(owner)s"

#, python-format
msgid "Scheduled run '%(name)s' by %(owner)s failed on %(repo)s."
msgstr "A execução agendada '%(name)s' de %(owner)s falhou em %(repo)s."

#, python-format
msgid "Agent run on %(repo)s succeeded"
msgstr "A execução do agente em %(repo)s teve sucesso"

#, python-format
msgid "Agent run on %(repo)s finished successfully."
