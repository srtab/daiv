#, python-format
msgid "Agent run on %(repo)s failed"
msgstr "A execução do agente em %(repo)s falhou"

#, python-format
msgid "Agent run on %(repo)s failed."
msgstr "A execução do agente em %(repo)s falhou."

#, python-format
msgid "'%(name)s' batch succeeded (%(total)d runs) — %(owner)s"
msgstr "O lote '%(name)s' teve sucesso (%(total)d execuções) — %(owner)s"

#, python-format
msgid "All %(total)d runs of '%(name)s' by %(owner)s finished successfully."
msgstr ""
"Todas as %(total)d execuções de '%(name)s' de %(owner)s terminaram com "
"sucesso."

#, python-format
msgid "'%(name)s' batch failed (%(total)d runs) — %(owner)s"
msgstr "O lote '%(name)s' falhou (%(total)d execuções) — %(owner)s"

#, python-format
msgid "All %(total)d runs of '%(name)s' by %(owner)s failed."
msgstr "Todas as %(total)d execuções de '%(name)s' de %(owner)s falharam."

#, python-format
msgid "'%(name)s' batch: %(ok)d/%(total)d succeeded — %(owner)s"
msgstr "Lote '%(name)s': %(ok)d/%(total)d com sucesso — %(owner)s"

#, python-format
msgid ""
"%(ok)d of %(total)d runs of '%(name)s' by %(owner)s succeeded; %(failed)d "
"failed."
msgstr ""
"%(ok)d de %(total)d execuções de '%(name)s' de %(owner)s tiveram sucesso; "
"%(failed)d falharam."

#, python-format
msgid "Agent run batch succeeded (%(total)d runs)"
msgstr "O lote de execuções do agente teve sucesso (%(total)d execuções)"

#, python-format
msgid "All %(total)d runs on %(repos)s finished successfully."
msgstr "Todas as %(total)d execuções em %(repos)s terminaram com sucesso."

#, python-format
msgid "Agent run batch failed (%(total)d runs)"
msgstr "O lote de execuções do agente falhou (%(total)d execuções)"

#, python-format
msgid "All %(total)d runs on %(repos)s failed."
msgstr "Todas as %(total)d execuções em %(repos)s falharam."

#, python-format
msgid "Agent run batch finished: %(ok)d/%(total)d succeeded"
msgstr "Lote de execuções do agente terminado: %(ok)d/%(total)d com sucesso"

#, python-format
msgid "%(ok)d of %(total)d runs on %(repos)s succeeded; %(failed)d failed."
msgstr ""
"%(ok)d de %(total)d execuções em %(repos)s tiveram sucesso; %(failed)d "
"falharam."

