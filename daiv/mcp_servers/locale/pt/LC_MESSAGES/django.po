msgstr "um nome de ferramenta por linha"

msgid "One tool name per line."
msgstr "Um nome de ferramenta por linha."

msgid ""
"Renaming an existing MCP server is not supported. Delete and re-create "
"instead."
msgstr ""
"Não é possível renomear um servidor MCP existente. Em vez disso, elimine e "
"crie novamente."

#, python-format
msgid "'%(name)s' is a reserved name and cannot be used."
msgstr "'%(name)s' é um nome reservado e não pode ser utilizado."

msgid ""
"At least one item is required when a filter mode other than 'none' is set."
msgstr ""
"É necessário pelo menos um item quando está definido um modo de filtro "
"diferente de 'none'."

msgid "🔒 keep existing"
msgstr "🔒 manter existente"

msgid "Header name cannot be empty."
msgstr "O nome do cabeçalho não pode estar vazio."

msgid "Invalid header name (RFC 7230 token characters only)."
msgstr "Nome de cabeçalho inválido (apenas caracteres de token RFC 7230)."

msgid "Environment variable name is required."
msgstr "O nome da variável de ambiente é obrigatório."

