{
  "FsDeleteRequest": {
    "properties": {
      "path": {
        "description": "Absolute file path under /workspace.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "FsDeleteRequest",
    "type": "object"
  },
  "FsDeleteResponse": {
    "$defs": {
      "FsError": {
        "properties": {
          "code": {
            "$ref": "#/$defs/FsErrorCode",
            "description": "Stable, machine-branchable error code."
          },
          "message": {
            "description": "Human-readable hint the agent can act on.",
            "minLength": 1,
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "FsError",
        "type": "object"
      },
      "FsErrorCode": {
        "enum": [
          "invalid_path",
          "not_found",
          "not_a_directory",
          "is_a_directory",
          "not_a_text_file",
          "invalid_pattern",
          "string_not_found",
          "multiple_occurrences",
          "already_exists",
          "too_large",
          "invalid_offset",
          "permission_denied",
          "exec_failed"
        ],
        "title": "FsErrorCode",
        "type": "string"
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "$ref": "#/$defs/FsError"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Structured error; null on success."
      },
      "removed": {
        "default": false,
        "description": "True if a file was actually removed; False if it was already absent.",
        "title": "Removed",
        "type": "boolean"
      }
    },
    "title": "FsDeleteResponse",
    "type": "object"
  },
