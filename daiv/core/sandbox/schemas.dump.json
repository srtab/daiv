        "type": "object"
      },
      "FsErrorCode": {
        "enum": [
          "invalid_path",
          "not_found",
          "not_a_directory",
          "is_a_directory",
          "not_a_text_file",
          "invalid_pattern",
          "string_not_found",
          "multiple_occurrences",
          "already_exists",
          "too_large",
          "invalid_offset",
          "permission_denied",
          "exec_failed"
        ],
        "title": "FsErrorCode",
        "type": "string"
      },
      "FsGrepMatch": {
        "properties": {
          "line": {
            "description": "1-indexed line number of the match.",
            "title": "Line",
            "type": "integer"
          },
          "path": {
            "description": "Absolute path of the matching file.",
            "title": "Path",
            "type": "string"
          },
          "text": {
            "description": "Text of the matching line.",
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "path",
          "line",
          "text"
        ],
        "title": "FsGrepMatch",
        "type": "object"
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "$ref": "#/$defs/FsError"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Structured error; null on success."
      },
      "matches": {
        "description": "Matches found (empty on error).",
        "items": {
          "$ref": "#/$defs/FsGrepMatch"
        },
        "title": "Matches",
        "type": "array"
      }
    },
    "title": "FsGrepResponse",
    "type": "object"
  },
