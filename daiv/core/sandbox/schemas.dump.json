  "FsGrepMatch": {
    "properties": {
      "line": {
        "description": "1-indexed line number of the match.",
        "title": "Line",
        "type": "integer"
      },
      "path": {
        "description": "Absolute path of the matching file.",
        "title": "Path",
        "type": "string"
      },
      "text": {
        "description": "Text of the matching line.",
        "title": "Text",
        "type": "string"
      }
    },
    "required": [
      "path",
      "line",
      "text"
    ],
    "title": "FsGrepMatch",
    "type": "object"
  },
  "FsGrepRequest": {
    "properties": {
      "case_insensitive": {
        "default": false,
        "description": "Match case-insensitively (ripgrep `-i` / POSIX `grep -i`).",
        "title": "Case Insensitive",
        "type": "boolean"
      },
      "exclude": {
        "description": "Directory basenames/globs to prune from the search (extends the server defaults).",
        "items": {
          "type": "string"
        },
        "title": "Exclude",
        "type": "array"
      },
      "glob": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Optional filename glob to restrict the search.",
        "title": "Glob"
      },
      "head_limit": {
        "anyOf": [
          {
            "minimum": 1,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Cap on the number of matches returned. None means uncapped (return every match).",
        "title": "Head Limit"
      },
      "multiline": {
        "default": false,
        "description": "Allow matches to span multiple lines, letting `.` match newlines (ripgrep `--multiline`). Not supported on the POSIX fallback, where it is silently ignored.",
        "title": "Multiline",
        "type": "boolean"
      },
      "path": {
        "description": "Absolute directory/file path under /workspace.",
        "title": "Path",
        "type": "string"
      },
      "pattern": {
        "description": "Regular expression to search for (Rust regex syntax, as evaluated by ripgrep). Regex is ALWAYS on \u2014 there is intentionally no literal mode, mirroring Claude Code's Grep tool. Metacharacters (e.g. `.`, `(`, `{`, `*`, `+`, `?`, `|`, `[`, `\\`) must be escaped to match them literally. When ripgrep is unavailable on the task image the search falls back to POSIX ERE (`grep -E`), whose flavor differs (libc ERE, not Rust regex).",
        "title": "Pattern",
        "type": "string"
      }
    },
    "required": [
      "pattern",
      "path"
    ],
    "title": "FsGrepRequest",
    "type": "object"
  },
  "FsGrepResponse": {
    "$defs": {
      "FsError": {
        "properties": {
          "code": {
            "$ref": "#/$defs/FsErrorCode",
            "description": "Stable, machine-branchable error code."
          },
          "message": {
            "description": "Human-readable hint the agent can act on.",
            "minLength": 1,
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
