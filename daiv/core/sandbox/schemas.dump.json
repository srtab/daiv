{
  "ApplyMutationsRequest": {
    "$defs": {
      "PutMutation": {
        "properties": {
          "content": {
            "description": "Base64-encoded full file content.",
            "format": "base64",
            "title": "Content",
            "type": "string"
          },
          "mode": {
            "description": "POSIX mode bits to set on the file.",
            "maximum": 4095,
            "minimum": 0,
            "title": "Mode",
            "type": "integer"
          },
          "path": {
            "description": "Absolute path inside the sandbox, must be under /workspace/repo.",
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "path",
          "content",
          "mode"
        ],
        "title": "PutMutation",
        "type": "object"
      }
    },
    "properties": {
      "mutations": {
        "items": {
          "$ref": "#/$defs/PutMutation"
        },
        "maxItems": 64,
        "minItems": 1,
        "title": "Mutations",
        "type": "array"
      }
    },
    "required": [
      "mutations"
    ],
    "title": "ApplyMutationsRequest",
    "type": "object"
  },
  "ApplyMutationsResponse": {
    "$defs": {
      "MutationResult": {
        "properties": {
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Per-item error message when ok=False.",
            "title": "Error"
          },
          "ok": {
            "description": "Whether the mutation was applied successfully.",
            "title": "Ok",
            "type": "boolean"
          },
          "path": {
            "description": "The path the mutation targeted.",
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "path",
          "ok"
        ],
        "title": "MutationResult",
        "type": "object"
      }
    },
    "properties": {
      "results": {
        "items": {
          "$ref": "#/$defs/MutationResult"
        },
        "title": "Results",
        "type": "array"
      }
    },
    "required": [
      "results"
    ],
    "title": "ApplyMutationsResponse",
    "type": "object"
  },
  "FsDeleteRequest": {
    "properties": {
      "path": {
        "description": "Absolute file path under /workspace.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "FsDeleteRequest",
    "type": "object"
  },
  "FsDeleteResponse": {
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Error"
      },
      "ok": {
        "title": "Ok",
        "type": "boolean"
      }
    },
    "required": [
      "ok"
    ],
    "title": "FsDeleteResponse",
    "type": "object"
  },
  "FsEditRequest": {
    "properties": {
      "new": {
        "description": "Replacement string.",
        "title": "New",
        "type": "string"
      },
      "old": {
        "description": "Exact substring to replace.",
        "title": "Old",
        "type": "string"
      },
      "path": {
        "description": "Absolute file path under /workspace.",
        "title": "Path",
        "type": "string"
      },
      "replace_all": {
        "default": false,
        "description": "Replace every occurrence.",
        "title": "Replace All",
        "type": "boolean"
      }
    },
    "required": [
      "path",
      "old",
      "new"
    ],
    "title": "FsEditRequest",
    "type": "object"
  },
  "FsEditResponse": {
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Error code/message on failure.",
        "title": "Error"
      },
      "occurrences": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Number of replacements made.",
        "title": "Occurrences"
      }
    },
    "title": "FsEditResponse",
    "type": "object"
  },
  "FsEntry": {
    "properties": {
      "is_dir": {
        "description": "Whether the entry is a directory.",
        "title": "Is Dir",
        "type": "boolean"
      },
      "path": {
        "description": "Absolute path of the entry.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path",
      "is_dir"
    ],
    "title": "FsEntry",
    "type": "object"
  },
  "FsGlobRequest": {
    "properties": {
      "path": {
        "description": "Absolute base directory under /workspace.",
        "title": "Path",
        "type": "string"
      },
      "pattern": {
        "description": "Glob pattern (supports *, **, ?, [abc]).",
        "title": "Pattern",
        "type": "string"
      }
    },
    "required": [
      "pattern",
      "path"
    ],
    "title": "FsGlobRequest",
    "type": "object"
  },
  "FsGlobResponse": {
    "$defs": {
      "FsEntry": {
        "properties": {
          "is_dir": {
            "description": "Whether the entry is a directory.",
            "title": "Is Dir",
            "type": "boolean"
          },
          "path": {
            "description": "Absolute path of the entry.",
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "path",
          "is_dir"
        ],
        "title": "FsEntry",
        "type": "object"
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Error message when the glob failed.",
        "title": "Error"
      },
      "matches": {
        "description": "Matching entries (empty on error).",
        "items": {
          "$ref": "#/$defs/FsEntry"
        },
        "title": "Matches",
        "type": "array"
      }
    },
    "title": "FsGlobResponse",
    "type": "object"
  },
  "FsGrepMatch": {
    "properties": {
      "line": {
        "description": "1-indexed line number of the match.",
        "title": "Line",
        "type": "integer"
      },
      "path": {
        "description": "Absolute path of the matching file.",
        "title": "Path",
        "type": "string"
      },
      "text": {
        "description": "Text of the matching line.",
        "title": "Text",
        "type": "string"
      }
    },
    "required": [
      "path",
      "line",
      "text"
    ],
    "title": "FsGrepMatch",
    "type": "object"
  },
  "FsGrepRequest": {
    "properties": {
      "glob": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Optional filename glob to restrict the search.",
        "title": "Glob"
      },
      "path": {
        "description": "Absolute directory/file path under /workspace.",
        "title": "Path",
        "type": "string"
      },
      "pattern": {
        "description": "Literal substring to search for (not a regex).",
        "title": "Pattern",
        "type": "string"
      }
    },
    "required": [
      "pattern",
      "path"
    ],
    "title": "FsGrepRequest",
    "type": "object"
  },
  "FsGrepResponse": {
    "$defs": {
      "FsGrepMatch": {
        "properties": {
          "line": {
            "description": "1-indexed line number of the match.",
            "title": "Line",
            "type": "integer"
          },
          "path": {
            "description": "Absolute path of the matching file.",
            "title": "Path",
            "type": "string"
          },
          "text": {
            "description": "Text of the matching line.",
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "path",
          "line",
          "text"
        ],
        "title": "FsGrepMatch",
        "type": "object"
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Error message when the search failed.",
        "title": "Error"
      },
      "matches": {
        "description": "Matches found (empty on error).",
        "items": {
          "$ref": "#/$defs/FsGrepMatch"
        },
        "title": "Matches",
        "type": "array"
      }
    },
    "title": "FsGrepResponse",
    "type": "object"
  },
  "FsLsRequest": {
    "properties": {
      "path": {
        "description": "Absolute directory path under /workspace.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "FsLsRequest",
    "type": "object"
  },
  "FsLsResponse": {
    "$defs": {
      "FsEntry": {
        "properties": {
          "is_dir": {
            "description": "Whether the entry is a directory.",
            "title": "Is Dir",
            "type": "boolean"
          },
          "path": {
            "description": "Absolute path of the entry.",
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "path",
          "is_dir"
        ],
        "title": "FsEntry",
        "type": "object"
      }
    },
    "properties": {
      "entries": {
        "description": "Directory entries (empty on error).",
        "items": {
          "$ref": "#/$defs/FsEntry"
        },
        "title": "Entries",
        "type": "array"
      },
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Error message when the listing failed.",
        "title": "Error"
      }
    },
    "title": "FsLsResponse",
    "type": "object"
  },
  "FsReadRequest": {
    "properties": {
      "limit": {
        "default": 2000,
        "description": "Maximum number of lines (text files only).",
        "minimum": 1,
        "title": "Limit",
        "type": "integer"
      },
      "offset": {
        "default": 0,
        "description": "0-indexed start line (text files only).",
        "minimum": 0,
        "title": "Offset",
        "type": "integer"
      },
      "path": {
        "description": "Absolute file path under /workspace.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path"
    ],
    "title": "FsReadRequest",
    "type": "object"
  },
  "FsReadResponse": {
    "properties": {
      "content": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "File content (utf-8 text or base64 binary). For an empty file this is a human-readable sentinel string (with encoding 'utf-8'), not the file's bytes.",
        "title": "Content"
      },
      "encoding": {
        "anyOf": [
          {
            "enum": [
              "utf-8",
              "base64"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Encoding of `content`: 'utf-8' for text, 'base64' for binary.",
        "title": "Encoding"
      },
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Error message when the read failed.",
        "title": "Error"
      }
    },
    "title": "FsReadResponse",
    "type": "object"
  },
  "FsWriteRequest": {
    "properties": {
      "content": {
        "description": "Base64-encoded full file content.",
        "format": "base64",
        "title": "Content",
        "type": "string"
      },
      "mode": {
        "default": 420,
        "description": "POSIX mode bits to set on the file.",
        "maximum": 4095,
        "minimum": 0,
        "title": "Mode",
        "type": "integer"
      },
      "path": {
        "description": "Absolute file path under /workspace.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path",
      "content"
    ],
    "title": "FsWriteRequest",
    "type": "object"
  },
  "FsWriteResponse": {
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Error"
      },
      "ok": {
        "title": "Ok",
        "type": "boolean"
      }
    },
    "required": [
      "ok"
    ],
    "title": "FsWriteResponse",
    "type": "object"
  },
  "MutationResult": {
    "properties": {
      "error": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Per-item error message when ok=False.",
        "title": "Error"
      },
      "ok": {
        "description": "Whether the mutation was applied successfully.",
        "title": "Ok",
        "type": "boolean"
      },
      "path": {
        "description": "The path the mutation targeted.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path",
      "ok"
    ],
    "title": "MutationResult",
    "type": "object"
  },
  "PutMutation": {
    "properties": {
      "content": {
        "description": "Base64-encoded full file content.",
        "format": "base64",
        "title": "Content",
        "type": "string"
      },
      "mode": {
        "description": "POSIX mode bits to set on the file.",
        "maximum": 4095,
        "minimum": 0,
        "title": "Mode",
        "type": "integer"
      },
      "path": {
        "description": "Absolute path inside the sandbox, must be under /workspace/repo.",
        "title": "Path",
        "type": "string"
      }
    },
    "required": [
      "path",
      "content",
      "mode"
    ],
    "title": "PutMutation",
    "type": "object"
  },
  "RunRequest": {
    "properties": {
      "commands": {
        "description": "List of bash commands to be executed in the sandbox.",
        "items": {
          "type": "string"
        },
        "title": "Commands",
        "type": "array"
      },
      "fail_fast": {
        "default": false,
        "description": "Stop execution immediately if any command fails (exit_code != 0). Defaults to False for backward compatibility.",
        "title": "Fail Fast",
        "type": "boolean"
      },
      "timeout": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Maximum execution time in seconds for each command. Overrides the server default (DAIV_SANDBOX_COMMAND_TIMEOUT). 0 means no timeout.",
        "title": "Timeout"
      }
    },
    "required": [
      "commands"
    ],
    "title": "RunRequest",
    "type": "object"
  },
  "RunResponse": {
    "$defs": {
      "RunResult": {
        "properties": {
          "command": {
            "description": "Command that was executed.",
            "title": "Command",
            "type": "string"
          },
          "exit_code": {
            "description": "Exit code of the command.",
            "title": "Exit Code",
            "type": "integer"
          },
          "output": {
            "description": "Output of the command.",
            "title": "Output",
            "type": "string"
          },
          "workdir": {
            "description": "Working directory of the command.",
            "title": "Workdir",
            "type": "string"
          }
        },
        "required": [
          "command",
          "output",
          "exit_code",
          "workdir"
        ],
        "title": "RunResult",
        "type": "object"
      }
    },
    "properties": {
      "patch": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "Base64-encoded patch with the changes.",
        "title": "Patch"
      },
      "results": {
        "description": "List of results of each command.",
        "items": {
          "$ref": "#/$defs/RunResult"
        },
        "title": "Results",
        "type": "array"
      }
    },
    "required": [
      "results",
      "patch"
    ],
    "title": "RunResponse",
    "type": "object"
  },
  "RunResult": {
    "properties": {
      "command": {
        "description": "Command that was executed.",
        "title": "Command",
        "type": "string"
      },
      "exit_code": {
        "description": "Exit code of the command.",
        "title": "Exit Code",
        "type": "integer"
      },
      "output": {
        "description": "Output of the command.",
        "title": "Output",
        "type": "string"
      },
      "workdir": {
        "description": "Working directory of the command.",
        "title": "Workdir",
        "type": "string"
      }
    },
    "required": [
      "command",
      "output",
      "exit_code",
      "workdir"
    ],
    "title": "RunResult",
    "type": "object"
  },
  "StartSessionRequest": {
    "properties": {
      "base_image": {
        "description": "Docker image to be used as the base image for the sandbox.",
        "title": "Base Image",
        "type": "string"
      },
      "cpus": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "CPUs to be used for the sandbox.",
        "title": "Cpus"
      },
      "environment": {
        "anyOf": [
          {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Environment variables to set in the container at startup.",
        "title": "Environment"
      },
      "extract_patch": {
        "default": false,
        "description": "Whether to extract a patch with the changes made by the executed commands.",
        "title": "Extract Patch",
        "type": "boolean"
      },
      "memory_bytes": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Memory in bytes to be used for the sandbox.",
        "title": "Memory Bytes"
      },
      "network_enabled": {
        "default": false,
        "description": "Whether to enable network for the sandbox.",
        "title": "Network Enabled",
        "type": "boolean"
      }
    },
    "required": [
      "base_image"
    ],
    "title": "StartSessionRequest",
    "type": "object"
  },
  "StartSessionResponse": {
    "properties": {
      "session_id": {
        "description": "Unique identifier for the session.",
        "title": "Session Id",
        "type": "string"
      }
    },
    "required": [
      "session_id"
    ],
    "title": "StartSessionResponse",
    "type": "object"
  }
}
